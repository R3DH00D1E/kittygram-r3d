    {
      "name": "08 Auth - POST /auth/jwt/create/ (save token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "if (jsonData.access) {",
              "    pm.collectionVariables.set('accessToken', jsonData.access);",
              "}",
              "pm.test('Access token saved', function () {",
              "    pm.expect(pm.collectionVariables.get('accessToken')).to.not.eql('');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
